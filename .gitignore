 
# ==========================================
# Python & Jupyter Notebook .gitignore
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints/

# Virtual Environments (Important to ignore!)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / Packaging
build/
dist/
*.egg-info/
.eggs/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# C extensions
*.so

# ==========================================
# C# & Visual Studio (WinForms)
# ==========================================

# Build results
[Bb]in/
[Oo]bj/

# Visual Studio specific files and folders
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vssscc

# NuGet Packages
*.nupkg
packages/
!packages/build/

# Publish profiles and outputs
*.pubxml
*.pubxml.user
Publish/

# Profiler and Test results
*.psess
*.vsp
*.vspx
*.vspcc
TestResults/

# Logs and Caches
*.log
*.cache

# ==========================================
# OS Specific Files
# ==========================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# Editor & OS Specific Files
# ==========================================

# VS Code / IDEs
.vscode/
.idea/
*.swp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db