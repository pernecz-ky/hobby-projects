 
# ==========================================
# Python & Jupyter Notebook .gitignore
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints/

# Virtual Environments (Important to ignore!)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / Packaging
build/
dist/
*.egg-info/
.eggs/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# C extensions
*.so

# ==========================================
# Editor & OS Specific Files
# ==========================================

# VS Code / IDEs
.vscode/
.idea/
*.swp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db